<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:parentTag="android.widget.LinearLayout">

    <TextView
        android:id="@+id/view_settings_about_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="26dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="26dp"
        android:fontFamily="@font/google_sans_regular"
        android:text="@string/view_settings_about_label"
        android:textColor="@color/text_secondary_color_light"
        android:textSize="@dimen/text_size_l" />

    <androidx.cardview.widget.CardView
        android:id="@+id/view_settings_version_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/settings_horizontal_margins"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="@dimen/settings_horizontal_margins"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="@dimen/settings_card_radius">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="4dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/view_settings_version_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/default_space_3"
                android:layout_marginEnd="@dimen/default_space_3"
                android:background="?android:selectableItemBackground"
                android:fontFamily="@font/google_sans_regular"
                android:gravity="center"
                android:paddingStart="@dimen/default_space"
                android:paddingEnd="@dimen/default_space"
                android:textSize="@dimen/text_size_xxl"
                android:textStyle="bold"
                tools:text="Version 1.0.0" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/view_settings_version_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="@dimen/default_space_3"
                android:layout_marginTop="@dimen/default_space_2"
                android:layout_marginEnd="@dimen/default_space_3"
                android:fontFamily="@font/google_sans_regular"
                android:gravity="center"
                android:textSize="@dimen/text_size_l" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</merge>